# case-study/.env.example
# Copy to case-study/.env and fill in your values.
# This file is safe to commit — it contains no real keys.

# ---------------------------------------------------------------------------
# Vast.ai (required for remote runs)
# ---------------------------------------------------------------------------
LLM_PROVIDER_KEY=your_vastai_api_key_here
LLM_VAST_SSH_KEY=~/.ssh/id_rsa

# ---------------------------------------------------------------------------
# Model (matches workload-contract.yaml)
# ---------------------------------------------------------------------------
LLM_MODEL=Qwen3.5-9B-Q4_K_M
LLM_VAST_HF_REPO=bartowski/Qwen2.5-7B-Instruct-GGUF
LLM_VAST_HF_FILE=Qwen3.5-9B-Q4_K_M.gguf

# ---------------------------------------------------------------------------
# GPU offer selection (tiered fallback: 8 → 4 → 2 → 1 GPUs)
# ---------------------------------------------------------------------------
LLM_VAST_NUM_GPUS=4
LLM_VAST_MIN_VRAM_GB=8
LLM_VAST_MAX_VRAM_GB=96
LLM_VAST_MAX_PRICE=1.0
LLM_VAST_MAX_BW_COST_USD=0.50
LLM_VAST_MIN_RELIABILITY=0.95
LLM_VAST_MIN_INET_DOWN_MBPS=1000
LLM_VAST_REQUIRE_DATACENTER=true
LLM_VAST_REQUIRE_VERIFIED=true

# ---------------------------------------------------------------------------
# VRAM / parallel slot formula
# n_parallel = (vram_gb - model_vram_gb) / kv_slot_gb
# For 16 GB/card: (16 - 6) / 0.5 = 20 slots/card
# ---------------------------------------------------------------------------
LLM_VAST_MODEL_VRAM_GB=6.0
LLM_VAST_KV_SLOT_GB=0.5

# ---------------------------------------------------------------------------
# Per-task calibration (calibrated on 1x RTX 3090 24GB)
# ---------------------------------------------------------------------------
LLM_VAST_AVG_INFERENCE_SECS_JOB_SKILLS=20
LLM_VAST_AVG_INFERENCE_SECS_JD_REPARSE=36
LLM_VAST_AVG_INFERENCE_SECS_JD_VALIDATE=33
LLM_VAST_AVG_INFERENCE_SECS_COMPANY_ENRICH=50

# ---------------------------------------------------------------------------
# Context windows
# ---------------------------------------------------------------------------
LLM_CONTEXT_WINDOW_JOB_SKILLS=4096
LLM_CONTEXT_WINDOW_JD_REPARSE=4096
LLM_CONTEXT_WINDOW_COMPANY_ENRICH=4096

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------
LLM_VAST_TIMEOUT_RUNNING=300
LLM_VAST_TIMEOUT_SSH=120
LLM_VAST_TIMEOUT_LOAD=600
LLM_VAST_MAX_DURATION_HOURS=4

# ---------------------------------------------------------------------------
# Local CPU emulation (no GPU cost)
# ---------------------------------------------------------------------------
CPU_LLM_BASE_URL=http://localhost:8085/v1
CPU_LLM_MODEL=Qwen3.5-9B-Q4_K_M
