# iterations/04-single-gpu-scaling/config.env
# High-TFLOPS single-GPU experiment: RTX PRO 6000 WS + RTX 5090
# Goal: test if "beefier" GPU (more TFLOPS, VRAM, bandwidth) scales throughput.
#
# KV cache recalibrated to 0.2 GB/slot (down from 0.5 GB initial estimate).
# n_parallel passed explicitly via --n-parallel to bench.sh, not auto-computed.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=1
LLM_VAST_MAX_PRICE=1.50
LLM_VAST_MIN_VRAM_GB=32
LLM_VAST_MAX_VRAM_GB=100
LLM_VAST_MIN_TFLOPS_PER_GPU=100
LLM_VAST_MIN_INET_DOWN_MBPS=500
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true

# KV cache recalibration: measured 0.2 GB/slot at 4096 ctx on Qwen3.5-9B Q4_K_M
LLM_VAST_KV_SLOT_GB=0.2

# Sub-runs in this iteration (see summary.md):
#   Run A: RTX PRO 6000 WS (96 GB) — n_parallel=100 override
#   Run B: RTX PRO 6000 WS (96 GB) — n_parallel=72  override
#   Run C: RTX 5090         (32 GB) — n_parallel=48  override
