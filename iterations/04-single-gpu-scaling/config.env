# iterations/04-single-gpu-scaling/config.env
# Index file — this iteration uses per-sub-run configs, not a single shared config.
# Pass the appropriate file as the 9th arg to bench.sh (see commands in summary.md).
#
# Sub-run configs:
#   config-pro6000-100slots.env  — RTX PRO 6000 WS, 100 slots (KV=0.9 GB)
#   config-pro6000-72slots.env   — RTX PRO 6000 WS,  72 slots (KV=1.25 GB)
#   config-5090-48slots.env      — RTX 5090,          48 slots (KV=0.54 GB)
#
# Common settings across all sub-runs:
#   MIN_TFLOPS_PER_GPU=100, REQUIRE_VERIFIED=true, MAX_BW_COST_USD=0.04, MAX_PRICE=0.89
