# iterations/04-single-gpu-scaling/config-pro6000-100slots.env
# RTX PRO 6000 WS/S — 100 parallel slots
#
# KV_SLOT_GB set to enforce exactly 100 slots:
#   n_parallel = floor((96 - 6) / 0.9) = floor(100.0) = 100
# This exceeds the real KV footprint (0.2 GB/slot measured) — we're
# deliberately limiting to 100 as a conservative first attempt.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=1
LLM_VAST_GPU_NAME=RTX PRO 6000
LLM_VAST_MAX_PRICE=0.89
LLM_VAST_MIN_VRAM_GB=90
LLM_VAST_MAX_VRAM_GB=100
LLM_VAST_MIN_TFLOPS_PER_GPU=100
LLM_VAST_MIN_INET_DOWN_MBPS=0
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04

# --- Slot calculation ---
LLM_VAST_KV_SLOT_GB=0.9
