# iterations/04-single-gpu-scaling/config-pro6000-72slots.env
# RTX PRO 6000 WS/S — 72 parallel slots (reduced from 100 to test bandwidth ceiling)
#
# KV_SLOT_GB set to enforce exactly 72 slots:
#   n_parallel = floor((96 - 6) / 1.25) = floor(72.0) = 72
# If 100 slots saturated the bandwidth bus, 72 should recover throughput.
# Spoiler: it doesn't — the ceiling is not parallel count, it's bandwidth.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=1
LLM_VAST_GPU_NAME=RTX PRO 6000
LLM_VAST_MAX_PRICE=0.89
LLM_VAST_MIN_VRAM_GB=90
LLM_VAST_MAX_VRAM_GB=100
LLM_VAST_MIN_TFLOPS_PER_GPU=100
LLM_VAST_MIN_INET_DOWN_MBPS=0
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04

# --- Slot calculation ---
LLM_VAST_KV_SLOT_GB=1.25
