# iterations/04-single-gpu-scaling/config-5090-48slots.env
# RTX 5090 — 48 parallel slots
#
# KV_SLOT_GB set to enforce exactly 48 slots:
#   n_parallel = floor((32 - 6) / 0.54) = floor(48.1) = 48
# RTX 5090 has higher memory bandwidth than 3090 (~1.8 TB/s vs ~0.9 TB/s).
# Hypothesis: same slot count but faster bandwidth → faster throughput.
# Reality: 1-1.5 min warmup on first batch; then caps same as PRO 6000 at ~100 rec/min.
# Best single run: ~270 rec/min (likely a lucky warmup-skipped result).
# Typical runs: ~200 rec/min — inconsistent, eventually discarded.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=1
LLM_VAST_GPU_NAME=RTX 5090
LLM_VAST_MAX_PRICE=0.89
LLM_VAST_MIN_VRAM_GB=31
LLM_VAST_MAX_VRAM_GB=35
LLM_VAST_MIN_TFLOPS_PER_GPU=100
LLM_VAST_MIN_INET_DOWN_MBPS=0
LLM_VAST_REQUIRE_DATACENTER=true
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04

# --- Slot calculation ---
LLM_VAST_KV_SLOT_GB=0.54
