# iterations/08-dc-reliability/config.env
# Unified DC config — reliable hardware at all fleet scales
#
# Purpose:
#   Non-DC hosts collapse under sustained multi-GPU inference load (proven in
#   iter 07: 4x RTX 3090 non-DC fails at ~5 min; RTX PRO 6000 WS non-DC at
#   ~11 min). This config proves that datacenter=true solves the stability
#   problem regardless of task type, including jd_reparse.
#
# Design choices:
#   - REQUIRE_DATACENTER=true: eliminates the host-crash failure mode entirely.
#   - NUM_GPUS=8: fallback path 8→4→2→1. DC supply is thinner than non-DC,
#     so fallbacks will activate more often — this is expected and handled.
#   - MAX_PRICE=1.60: DC 8x RTX 50xx-series reaches ~$1.50/hr. Setting 1.60
#     ensures the 50-59 range is reachable without being excluded by rounding.
#   - MIN_MEM_BW_PER_GPU=480: primary GPU quality filter. LLM decode is
#     memory-bandwidth-bound, not TFLOPS-bound. 480 GB/s (490 - 10 deviation
#     margin) admits RTX 30/40/50-series gaming cards and excludes low-bandwidth
#     outliers (RTX 2060, RTX 3060, etc.) without targeting specific models.
#     TFLOPS filter is set low — bandwidth is the gate that matters.
#   - MIN_TFLOPS_PER_GPU=1: effectively disabled. Bandwidth filter does the work.
#   - MIN_INET_DOWN_MBPS=700: DC hosts deliver stable 700 Mbps reliably.
#     A guaranteed 700 Mbps DC link is more predictable than a non-DC host
#     nominally advertising 1500–2000 Mbps but throttling under load.
#   - TIMEOUT_LOAD=600: DC instances boot and load model faster than non-DC
#     (no thermal throttle on startup). 600s is generous headroom for 8x.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=8
LLM_VAST_GPU_NAME=
LLM_VAST_MAX_PRICE=0.90
LLM_VAST_MIN_VRAM_GB=16
LLM_VAST_MAX_VRAM_GB=36
LLM_VAST_MIN_TFLOPS_PER_GPU=1
LLM_VAST_MIN_MEM_BW_PER_GPU=480
LLM_VAST_MIN_INET_DOWN_MBPS=700
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
LLM_VAST_TIMEOUT_LOAD=600
# Preserve instance on failure for SSH log inspection (llama-server stderr, dmesg).
# Destroy manually afterward: vastai destroy instance <id>
LLM_VAST_KEEP_ON_FAILURE=true
