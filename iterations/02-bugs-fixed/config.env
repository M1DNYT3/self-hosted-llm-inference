# iterations/02-bugs-fixed/config.env
# Vast.ai single-GPU simulation: rent a 2x RTX 3090 bundle, use only GPU 0.
# This reproduces the hardware tier available when the n_parallel bug was first fixed.
#
# SINGLE_GPU_MODE rents the matched bundle but starts llama-server only on
# CUDA_VISIBLE_DEVICES=0 and computes n_parallel for one card only.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=2
LLM_VAST_GPU_NAME=3090
LLM_VAST_MAX_PRICE=0.30
LLM_VAST_MIN_VRAM_GB=20
LLM_VAST_MAX_VRAM_GB=28
LLM_VAST_MIN_TFLOPS_PER_GPU=20
LLM_VAST_MIN_INET_DOWN_MBPS=0
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true

# Bandwidth cost filter is retained: reject hosts where model download cost
# (inet_down_cost × model_vram_gb) exceeds this threshold in USD.
LLM_VAST_MAX_BW_COST_USD=0.50

# --- Single-GPU mode ---
LLM_VAST_SINGLE_GPU_MODE=true
