# iterations/07-multi-gpu-mvp/config-8x.env
# 8x GPU bundle — first-time exploration beyond current production scale
#
# Not run in production. Intent: determine whether the fleet-scaling law
# holds past 4x (i.e. ~2× 4x throughput at ~2× 4x cost, or better).
#
# Design choices:
#   - NUM_GPUS=8: tiered fallback tries 8→4→2→1 if no 8x offer found.
#     If the run falls back to 4x, results are comparable to config-4x.env
#     and are reported as a 4x data point.
#   - TFLOPS floor is lower than config-4x.env: 13/GPU (vs 25/GPU for 4x).
#     Rationale: a 4x fleet needs ≥100 TFLOPS total → 25/GPU.
#     An 8x fleet needs the same ≥100 total → 100/8 = 12.5 → 13/GPU.
#     This admits RTX 2080 Ti (~13.4 TFLOPS/GPU, ~107 total for 8x) with
#     ~500 GB/s bandwidth — meeting the minimum fleet throughput bar at lower cost.
#   - At 8x cards × 20 slots/card = 160 total workers. Even if each card is
#     only 16 GB (20 KV slots), total throughput should approach or exceed
#     the single RTX 3090 (109 rec/min) × 8 = ~870 rec/min theoretical ceiling.
#     In practice the SSH tunnel + host bandwidth become the next bottleneck.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=8
LLM_VAST_GPU_NAME=
LLM_VAST_MAX_PRICE=0.90
LLM_VAST_MIN_VRAM_GB=16
LLM_VAST_MAX_VRAM_GB=36
LLM_VAST_MIN_TFLOPS_PER_GPU=13
LLM_VAST_MIN_INET_DOWN_MBPS=800
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
# 8x servers load simultaneously; allow extra time vs the default
LLM_VAST_TIMEOUT_LOAD=600
