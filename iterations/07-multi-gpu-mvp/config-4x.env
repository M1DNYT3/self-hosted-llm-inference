# iterations/07-multi-gpu-mvp/config-4x.env
# 4x GPU bundle — replicates current production configuration
#
# Design choices:
#   - NUM_GPUS=4: tiered fallback tries 4→2→1 if no 4x offer found
#   - No GPU_NAME filter: open to any RTX 2xxx–5xxx card — the filter
#     intentionally admits all three plausible 4x options in this price range:
#
#     Card             TFLOPS (4x)  Bandwidth/card  Non-DC price   Notes
#     RTX 4070S Ti     ~170 total   ~580 GB/s       $0.39–0.45/hr  prod reference
#     RTX 5070 Ti      ~170 total   ~760 GB/s       $0.30–0.40/hr  preferred: same TFLOPS,
#                                                                   higher bandwidth, cheaper
#     RTX 5060 Ti      ~90–100 tot  ~360 GB/s       $0.30–0.40/hr  risk: bandwidth limited;
#                                                                   expect lower rec/min per slot
#
#   - MIN_TFLOPS_PER_GPU=25: floor ensures ≥100 TFLOPS across a 4-card fleet.
#     Excludes RTX 5060 Ti (~22–23 TFLOPS/GPU) whose low memory bandwidth
#     (~360 GB/s) would drag per-slot throughput below the 4070S Ti / 5070 Ti
#     range. TFLOPS is not a throughput predictor for autoregressive decode —
#     bandwidth is — but 25/GPU is the minimum that keeps the fleet coherent.
#   - MIN_VRAM_GB=16: accommodates all 16 GB cards in the target range.
#     n_parallel = (16 - 6) / 0.5 = 20 slots/GPU × 4 = 80 total workers.
#   - MAX_VRAM_GB=36: caps at 5090 tier; excludes PRO 6000 WS (96 GB).
#   - MIN_INET_DOWN_MBPS=800: relaxed from 1000. At 4× GPUs runtime dominates
#     model download time even on a slightly slower link.
#   - REQUIRE_DATACENTER=false: fleet scaling proof-of-concept, not SLA uptime.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=4
LLM_VAST_GPU_NAME=
LLM_VAST_MAX_PRICE=0.90
LLM_VAST_MIN_VRAM_GB=16
LLM_VAST_MAX_VRAM_GB=36
LLM_VAST_MIN_TFLOPS_PER_GPU=25
LLM_VAST_MIN_INET_DOWN_MBPS=800
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
