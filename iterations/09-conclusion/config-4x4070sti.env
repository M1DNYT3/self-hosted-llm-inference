# iterations/09-conclusion/config-4x4070sti.env
# Supplemental run: 4x RTX 4070S Ti validation
#
# Purpose:
#   Confirm the production run result (369 rec/min, $0.023/1k) that appeared
#   in earlier docs as "pending case study replication." Three offers currently
#   available on Vast.ai.
#
# Design choices:
#   - LLM_VAST_GPU_NAME: pins to 4070 Super Ti family; auto-selects cheapest
#     of the available offers unless LLM_OFFER_ID is set explicitly.
#   - NUM_GPUS=4: matches original production run config.
#   - VRAM: 16 GB/card → (16 - 6) / 0.5 = 20 slots/card × 4 = 80 total workers.
#   - TFLOPS floor disabled (=1): bandwidth is the metric that matters; 4070S Ti
#     passes the 480 GB/s bandwidth gate comfortably (672 GB/s).
#   - REQUIRE_DATACENTER=false: non-DC confirmed stable for job_skills/company_enrich
#     in prior iterations.
#   - TIMEOUT_LOAD=600: retained from iter 09; safe default for any 4x config.
#   - KEEP_ON_FAILURE=true: preserve instance on failure for SSH inspection.
#     Change to false once the run completes cleanly.
#
# To pin a specific offer (optional):
#   LLM_OFFER_ID=<offer_id> bash harness/bench.sh 09-conclusion job_skills 2000 ...
#   Note: when LLM_OFFER_ID is set, pass --n-parallel 80 explicitly (arg 4)
#   because the slot formula is skipped in the fixed-offer path.
#
# Without pinning (recommended):
#   bash harness/bench.sh 09-conclusion job_skills 2000 0 "" "" remote "" \
#     iterations/09-conclusion/config-4x4070sti.env

# --- Offer selection ---
LLM_VAST_NUM_GPUS=4
LLM_VAST_GPU_NAME=RTX 4070S Ti
LLM_VAST_MIN_PRICE=0.40
LLM_VAST_MAX_PRICE=0.80
LLM_VAST_MIN_VRAM_GB=14
LLM_VAST_MAX_VRAM_GB=18
LLM_VAST_MIN_TFLOPS_PER_GPU=1
LLM_VAST_MIN_MEM_BW_PER_GPU=480
LLM_VAST_MIN_INET_DOWN_MBPS=700
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
LLM_VAST_TIMEOUT_LOAD=600
LLM_VAST_KEEP_ON_FAILURE=true
