# iterations/09-conclusion/config.env
# Final validation config — non-DC, per-GPU SSH fix applied
#
# Purpose:
#   Validate that the per-GPU SSH tunnel fix (iter 08 root cause) resolves
#   connection failures across all three tasks at 2000 records each.
#   Non-DC hardware confirmed stable for job_skills and company_enrich in
#   prior iterations; jd_reparse is the new addition at this batch size.
#
# Design choices:
#   - REQUIRE_DATACENTER=false: non-DC is cheaper and was not the failure source.
#     Hardware stability was never the issue — SSH channel exhaustion was.
#   - NUM_GPUS=8: same fallback path 8→4→2→1 as iter 08.
#   - MAX_PRICE=0.90: non-DC 8x RTX 30/40-series comfortably within range.
#   - MIN_MEM_BW_PER_GPU=480: bandwidth quality gate, retained from iter 08.
#     Excludes low-bandwidth outliers; TFLOPS filter disabled (set to 1).
#   - MIN_INET_DOWN_MBPS=700: guards against slow model download.
#   - KEEP_ON_FAILURE=false: fix is expected to hold; destruction on failure
#     is the correct default for normal operation.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=8
LLM_VAST_GPU_NAME=
#LLM_VAST_MIN_PRICE=0.56
LLM_VAST_MAX_PRICE=0.90
LLM_VAST_MIN_VRAM_GB=20
LLM_VAST_MAX_VRAM_GB=36
LLM_VAST_MIN_TFLOPS_PER_GPU=1
LLM_VAST_MIN_MEM_BW_PER_GPU=480
LLM_VAST_MIN_INET_DOWN_MBPS=700
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
LLM_VAST_TIMEOUT_LOAD=600
LLM_VAST_KEEP_ON_FAILURE=false
