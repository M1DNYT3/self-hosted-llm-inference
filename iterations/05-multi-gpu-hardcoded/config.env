# iterations/05-multi-gpu-hardcoded/config.env
# 2x RTX 5090 — hardcoded dual-GPU, no fallback to 1
#
# Design constraints of this iteration:
#   - NUM_GPUS=2 hardcoded at startup; no tiered fallback
#   - onstart script has TWO hardcoded llama-server launch blocks (one per GPU),
#     not generated dynamically from GPU count. Adding a 3rd GPU would require
#     manually editing the onstart. This limitation motivates iteration 06.
#   - Thread-affinity routing: thread_id % 2 determines which GPU receives request
#   - n_parallel = slots_per_gpu × 2 (VRAM formula applied per-card, then multiplied)
#
# Expected: ~94 workers (47 slots/card × 2 cards)
# Cost: ~$0.65/hr for a 2x RTX 5090 bundle
#
# Filters match single-5090 config (iter 04C) — same GPU, just 2 of them.
# MAX_PRICE set to $0.90 (2× the single-card ceiling with headroom).
# REQUIRE_DATACENTER=false to widen availability and reduce cost.

# --- Offer selection ---
LLM_VAST_NUM_GPUS=2
LLM_VAST_GPU_NAME=RTX 5090
LLM_VAST_MIN_PRICE=0.65
LLM_VAST_MAX_PRICE=0.90
LLM_VAST_MIN_VRAM_GB=31
LLM_VAST_MAX_VRAM_GB=35
LLM_VAST_MIN_TFLOPS_PER_GPU=100
LLM_VAST_MIN_INET_DOWN_MBPS=1000
LLM_VAST_REQUIRE_DATACENTER=false
LLM_VAST_REQUIRE_VERIFIED=true
LLM_VAST_MAX_BW_COST_USD=0.04
